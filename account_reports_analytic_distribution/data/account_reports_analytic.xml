<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================================
         General Ledger – add Analytic Distribution column + expression
         ================================================================ -->

    <!-- New expression linked to the existing General Ledger report line.
         The subformula key must match what _report_custom_engine_general_ledger
         now returns ('analytic_distribution'). -->
    <record id="general_ledger_line_analytic_distribution" model="account.report.expression">
        <field name="label">analytic_distribution</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_general_ledger</field>
        <field name="subformula">analytic_distribution</field>
        <field name="report_line_id" ref="account_reports.general_ledger_custom_engine_line"/>
    </record>

    <!-- New column on the General Ledger report -->
    <record id="general_ledger_report_analytic_distribution" model="account.report.column">
        <field name="name">Analytic</field>
        <field name="expression_label">analytic_distribution</field>
        <field name="figure_type">string</field>
        <field name="report_id" ref="account_reports.general_ledger_report"/>
    </record>

    <!-- ================================================================
         Partner Ledger – add Analytic Distribution column only
         (the dynamic-lines handler picks it up via
          _get_additional_column_aml_values / _get_report_line_move_line)
         ================================================================ -->
    <record id="partner_ledger_report_analytic_distribution" model="account.report.column">
        <field name="name">Analytic</field>
        <field name="expression_label">analytic_distribution</field>
        <field name="figure_type">string</field>
        <field name="report_id" ref="account_reports.partner_ledger_report"/>
    </record>
</odoo>
